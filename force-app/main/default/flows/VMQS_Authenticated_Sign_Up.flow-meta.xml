<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>67.0</apiVersion>
    <decisions>
        <name>Decision_Shifts_Available</name>
        <label>Shifts Available?</label>
        <locationX>176</locationX>
        <locationY>254</locationY>
        <defaultConnector><targetReference>Screen_No_Shifts</targetReference></defaultConnector>
        <defaultConnectorLabel>No Shifts</defaultConnectorLabel>
        <rules>
            <name>outcome_ShiftsExist</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>colShifts</leftValueReference>
                <operator>IsNull</operator>
                <rightValue><booleanValue>false</booleanValue></rightValue>
            </conditions>
            <connector><targetReference>Screen_Select_Shift</targetReference></connector>
            <label>Has Shifts</label>
        </rules>
    </decisions>
    <decisions>
        <name>Decision_Already_Signed_Up</name>
        <label>Already Signed Up?</label>
        <locationX>176</locationX>
        <locationY>614</locationY>
        <defaultConnector><targetReference>Get_Shift_Capacity</targetReference></defaultConnector>
        <defaultConnectorLabel>Not Signed Up</defaultConnectorLabel>
        <rules>
            <name>outcome_AlreadySignedUp</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>recExistingAssignment.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue><booleanValue>false</booleanValue></rightValue>
            </conditions>
            <connector><targetReference>Screen_Already_Signed_Up</targetReference></connector>
            <label>Already Signed Up</label>
        </rules>
    </decisions>
    <decisions>
        <name>Decision_Capacity_Check</name>
        <label>Capacity Available?</label>
        <locationX>176</locationX>
        <locationY>854</locationY>
        <defaultConnector><targetReference>Screen_At_Capacity</targetReference></defaultConnector>
        <defaultConnectorLabel>At Capacity</defaultConnectorLabel>
        <rules>
            <name>outcome_HasCapacity</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>recSelectedShift.RemainingCapacity</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue><numberValue>0</numberValue></rightValue>
            </conditions>
            <connector><targetReference>Create_Assignment</targetReference></connector>
            <label>Has Capacity</label>
        </rules>
    </decisions>
    <description>Allows authenticated portal volunteers to browse all available shifts and sign up. Uses the logged-in user&apos;s Contact ID to create the JobPositionAssignment. Enforces capacity and prevents duplicate signups.</description>
    <dynamicChoiceSets>
        <name>choiceShifts</name>
        <collectionReference>colShifts</collectionReference>
        <dataType>String</dataType>
        <displayField>Start_and_End_DateTime__c</displayField>
        <object>JobPositionShift</object>
        <valueField>Id</valueField>
    </dynamicChoiceSets>
    <interviewLabel>VMQS Authenticated Sign Up {!$Flow.CurrentDateTime}</interviewLabel>
    <label>VMQS - Authenticated Volunteer Sign Up</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value><stringValue>LightningFlowBuilder</stringValue></value>
    </processMetadataValues>
    <processType>Flow</processType>
    <recordCreates>
        <name>Create_Assignment</name>
        <label>Create Assignment</label>
        <locationX>176</locationX>
        <locationY>974</locationY>
        <connector><targetReference>Screen_Confirmation</targetReference></connector>
        <inputAssignments>
            <field>AssignedContactId</field>
            <value><elementReference>$User.ContactId</elementReference></value>
        </inputAssignments>
        <inputAssignments>
            <field>AssignedPositionShiftId</field>
            <value><elementReference>pick_Shift</elementReference></value>
        </inputAssignments>
        <inputAssignments>
            <field>Status</field>
            <value><stringValue>Upcoming</stringValue></value>
        </inputAssignments>
        <inputAssignments>
            <field>DoesCountTowardShiftCapacity</field>
            <value><booleanValue>true</booleanValue></value>
        </inputAssignments>
        <object>JobPositionAssignment</object>
    </recordCreates>
    <recordLookups>
        <name>Get_Available_Shifts</name>
        <label>Get All Available Shifts</label>
        <locationX>176</locationX>
        <locationY>134</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector><targetReference>Decision_Shifts_Available</targetReference></connector>
        <filterLogic>AND</filterLogic>
        <filters>
            <field>Status</field>
            <operator>EqualTo</operator>
            <value><stringValue>In Progress</stringValue></value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>JobPositionShift</object>
        <outputReference>colShifts</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>Start_and_End_DateTime__c</queriedFields>
        <queriedFields>RemainingCapacity</queriedFields>
        <queriedFields>MaximumAttendeesCount</queriedFields>
    </recordLookups>
    <recordLookups>
        <name>Get_Existing_Assignment</name>
        <label>Check Existing Assignment</label>
        <locationX>176</locationX>
        <locationY>494</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector><targetReference>Decision_Already_Signed_Up</targetReference></connector>
        <filterLogic>AND</filterLogic>
        <filters>
            <field>AssignedContactId</field>
            <operator>EqualTo</operator>
            <value><elementReference>$User.ContactId</elementReference></value>
        </filters>
        <filters>
            <field>AssignedPositionShiftId</field>
            <operator>EqualTo</operator>
            <value><elementReference>pick_Shift</elementReference></value>
        </filters>
        <filters>
            <field>Status</field>
            <operator>NotEqualTo</operator>
            <value><stringValue>Canceled</stringValue></value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>JobPositionAssignment</object>
        <outputReference>recExistingAssignment</outputReference>
        <queriedFields>Id</queriedFields>
    </recordLookups>
    <recordLookups>
        <name>Get_Shift_Capacity</name>
        <label>Get Shift Remaining Capacity</label>
        <locationX>176</locationX>
        <locationY>734</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector><targetReference>Decision_Capacity_Check</targetReference></connector>
        <filterLogic>AND</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value><elementReference>pick_Shift</elementReference></value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>JobPositionShift</object>
        <outputReference>recSelectedShift</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>RemainingCapacity</queriedFields>
        <queriedFields>MaximumAttendeesCount</queriedFields>
    </recordLookups>
