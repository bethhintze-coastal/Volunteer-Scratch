<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Volunteer Portal Access</label>
    <description>Grants authenticated volunteers access to portal objects for shift management, history, and profile updates.</description>
    <hasActivationRequired>false</hasActivationRequired>

    <!-- Contact: read and edit own record -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Contact</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- VolunteerInitiative: read published initiatives -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>VolunteerInitiative</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- JobPosition: read to see role info on shifts -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>JobPosition</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- JobPositionShift: read to browse available shifts -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>JobPositionShift</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- JobPositionAssignment: create to sign up, edit to cancel -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>JobPositionAssignment</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- PersonCompetency: full CRUD on own skills -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>PersonCompetency</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Competency: read to support skill lookup -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Competency</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
</PermissionSet>
