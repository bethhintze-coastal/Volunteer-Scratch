<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Volunteer Coordinator</label>
    <description>Full CRUD access to all volunteer management objects for internal volunteer coordinators. Includes ability to run all volunteer management flows and business processes.</description>
    <hasActivationRequired>false</hasActivationRequired>

    <!-- System Permissions -->
    <userPermissions>
        <enabled>true</enabled>
        <name>RunFlow</name>
    </userPermissions>

    <!-- VolunteerInitiative: CRUD -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>VolunteerInitiative</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- JobPosition: CRUD -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>JobPosition</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- JobPositionShift: CRUD -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>JobPositionShift</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- JobPositionAssignment: CRUD -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
