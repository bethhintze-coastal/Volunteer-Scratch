        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>JobPositionAssignment</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- PersonCompetency: CRUD -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>PersonCompetency</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Competency: CRUD -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Competency</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Volunteer_Program_Interest__c: CRUD -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Volunteer_Program_Interest__c</object>
