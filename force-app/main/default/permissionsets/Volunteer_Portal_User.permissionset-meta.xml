<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Volunteer Portal User</label>
    <description>Authenticated portal volunteer permissions. View shifts/initiatives, sign up/cancel/reschedule via flows, manage own profile, skills, and interests. Cannot edit coordinator-set shift or initiative records.</description>
    <hasActivationRequired>false</hasActivationRequired>

    <!-- System Permissions -->
    <userPermissions>
        <enabled>true</enabled>
        <name>RunFlow</name>
    </userPermissions>

    <!-- VolunteerInitiative: Read only -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>VolunteerInitiative</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- JobPosition: Read only -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>JobPosition</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- JobPositionShift: Read only — volunteers cannot edit shift details -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>JobPositionShift</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- JobPositionAssignment: Read, Create, Edit (own records via sharing; flows enforce business logic) -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>JobPositionAssignment</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- PersonCompetency: Full CRUD on own skills -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>PersonCompetency</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Competency: Read only (skill lookup) -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Competency</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Volunteer_Program_Interest__c: Full CRUD on own interests -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Volunteer_Program_Interest__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Contact: Read, Edit own record -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Contact</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Account: Read, Edit own Person Account (availability fields) -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Account</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Account custom fields: availability editable, hours/milestone read only -->
    <fieldPermissions>
        <editable>false</editable>
        <field>Account.Total_Volunteer_Hours__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Account.Current_Milestone__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Account.Preferred_Days__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Account.Preferred_Times__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Account.Availability_Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Account.Availability_Notes__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- JobPositionAssignment: only Status and Waitlist_Position editable by volunteer -->
    <fieldPermissions>
        <editable>false</editable>
        <field>JobPositionAssignment.Role__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>JobPositionAssignment.Waitlist_Position__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>JobPositionAssignment.Email__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>JobPositionAssignment.First_Name__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>JobPositionAssignment.Last_Name__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>JobPositionAssignment.Mass_Quick_Update_Field__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>JobPositionAssignment.What_motivated_you_to_Volunteer__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>JobPositionAssignment.Would_you_recommend__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>JobPositionAssignment.Created_From_Sign_Up_Link__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>JobPositionAssignment.External_ID__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>JobPositionAssignment.Volunteer_ID__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- JobPositionShift custom fields: all read only -->
    <fieldPermissions>
        <editable>false</editable>
        <field>JobPositionShift.Default_Duration__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>JobPositionShift.External_ID__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>JobPositionShift.Start_and_End_DateTime__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>JobPositionShift.Volunteer_Signup_URL__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- VolunteerInitiative custom fields: all read only -->
    <fieldPermissions>
        <editable>false</editable>
        <field>VolunteerInitiative.Default_Duration__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>VolunteerInitiative.External_ID__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>VolunteerInitiative.Volunteer_Signup_URL__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- Volunteer_Program_Interest__c fields -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Volunteer_Program_Interest__c.Volunteer__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Volunteer_Program_Interest__c.Volunteer_Initiative__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Volunteer_Program_Interest__c.Notes__c</field>
        <readable>true</readable>
    </fieldPermissions>
</PermissionSet>
