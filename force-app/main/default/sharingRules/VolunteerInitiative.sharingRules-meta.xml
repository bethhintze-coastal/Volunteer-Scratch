<?xml version="1.0" encoding="UTF-8"?>
<SharingRules xmlns="http://soap.sforce.com/2006/04/metadata">
    <!-- Authenticated portal users see published, active initiatives -->
    <criteriaBasedRules>
        <fullName>Portal_Access_for_Volunteer_Initiative</fullName>
        <accessLevel>Read</accessLevel>
        <booleanFilter>1 AND 2</booleanFilter>
        <description>Shares published, active Volunteer Initiatives to authenticated Community users so they can browse and sign up for events.</description>
        <label>Portal Access for Volunteer Initiative</label>
        <includeRecordsOwnedByAll>true</includeRecordsOwnedByAll>
        <sharedTo>
            <allCustomerPortalUsers>true</allCustomerPortalUsers>
        </sharedTo>
        <criteriaItems>
            <field>IsPublished</field>
            <operation>equals</operation>
            <value>True</value>
        </criteriaItems>
        <criteriaItems>
            <field>Status</field>
            <operation>equals</operation>
            <value>In Progress</value>
        </criteriaItems>
    </criteriaBasedRules>
    <!-- Guest (unauthenticated) users see published, active initiatives -->
    <sharingGuestRules>
        <fullName>Guest_Access_for_Volunteer_Initiative</fullName>
        <accessLevel>Read</accessLevel>
        <booleanFilter>1 AND 2</booleanFilter>
        <description>This enables volunteer signups by providing access publicly based on Status and the Is Published checkbox.</description>
        <label>Guest Access for Volunteer Initiative</label>
        <sharedTo>
            <guestUser>Volunteer_Sign_Up</guestUser>
        </sharedTo>
        <criteriaItems>
            <field>IsPublished</field>
            <operation>equals</operation>
            <value>True</value>
        </criteriaItems>
        <criteriaItems>
            <field>Status</field>
            <operation>equals</operation>
            <value>In Progress</value>
        </criteriaItems>
    </sharingGuestRules>
</SharingRules>
